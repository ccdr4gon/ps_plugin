<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest
    Version="7.0"
    ExtensionBundleId="com.ccd.colorpalette.cep"
    ExtensionBundleVersion="1.0.5"
    ExtensionBundleName="Color Palette">
    <ExtensionList>
        <Extension Id="com.ccd.colorpalette.cep.panel" Version="1.0.5" />
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="PHXS" Version="[23.0,99.9]" />
            <Host Name="PHSP" Version="[23.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="5.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="com.ccd.colorpalette.cep.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <ScriptPath>./jsx/colorPalette.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--high-dpi-support=1</Parameter>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>调色盘</Menu>
                    <Geometry>
                        <Size>
                            <Width>240</Width>
                            <Height>520</Height>
                        </Size>
                        <MinSize>
                            <Width>230</Width>
                            <Height>180</Height>
                        </MinSize>
                        <MaxSize>
                            <Width>600</Width>
                            <Height>1200</Height>
                        </MaxSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
